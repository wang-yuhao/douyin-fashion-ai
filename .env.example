# ============================================================
# douyin-fashion-ai - Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# ============================================================

# --------------------------
# App
# --------------------------
APP_ENV=development
APP_PORT=3000
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_BASE_URL=http://localhost:3000

# --------------------------
# Database (PostgreSQL)
# --------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/douyin_fashion_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --------------------------
# Redis (Queue + Cache)
# --------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_DB=1
REDIS_CACHE_DB=2

# --------------------------
# Object Storage
# --------------------------
# Alibaba OSS (China primary)
OSS_ACCESS_KEY_ID=your-oss-access-key
OSS_ACCESS_KEY_SECRET=your-oss-secret
OSS_BUCKET_NAME=douyin-fashion-ai-assets
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# AWS S3 (global / fallback)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=douyin-fashion-ai-global
AWS_REGION=ap-southeast-1

# --------------------------
# Auth
# --------------------------
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# --------------------------
# Inference Providers
# --------------------------
# Kling (primary image-to-video)
KLING_API_KEY=your-kling-api-key
KLING_API_BASE_URL=https://api.klingai.com/v1
KLING_DEFAULT_MODEL=kling-v3
KLING_TIMEOUT_SECONDS=600

# Veo (premium route)
VEO_API_KEY=your-veo-api-key
VEO_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
VEO_DEFAULT_MODEL=veo-3.1
VEO_TIMEOUT_SECONDS=900

# Fallback provider (economy route)
FALLBACK_PROVIDER_API_KEY=your-fallback-api-key
FALLBACK_PROVIDER_BASE_URL=https://api.your-fallback-provider.com/v1
FALLBACK_TIMEOUT_SECONDS=300

# --------------------------
# Inference Router
# --------------------------
DEFAULT_INFERENCE_ROUTE=standard
PREMIUM_ROUTE_ENABLED=true
ECONOMY_ROUTE_ENABLED=true
ROUTER_MAX_RETRIES=3
ROUTER_RETRY_DELAY_SECONDS=10

# --------------------------
# Moderation
# --------------------------
MODERATION_ENABLED=true
MODERATION_PROVIDER=internal
MODERATION_STRICTNESS=standard
# Options: permissive, standard, strict

# --------------------------
# Prompt Service
# --------------------------
PROMPT_ENHANCEMENT_ENABLED=true
PROMPT_MAX_TOKENS=2000
PROMPT_LANGUAGE_DEFAULT=zh-CN
# Options: zh-CN, en

# --------------------------
# Billing
# --------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# For China payments
WECHAT_PAY_APP_ID=your-wechat-pay-app-id
WECHAT_PAY_MCH_ID=your-wechat-pay-mch-id
WECHAT_PAY_API_KEY=your-wechat-pay-api-key
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key

# --------------------------
# Credit Costs (internal, in USD cents)
# --------------------------
CREDIT_COST_ECONOMY_ROUTE=150
CREDIT_COST_STANDARD_ROUTE=450
CREDIT_COST_PREMIUM_ROUTE=1500
CREDIT_COST_PREVIEW=25
CREDIT_COST_STORAGE_GB_MONTH=10

# --------------------------
# Video Generation Defaults
# --------------------------
DEFAULT_VIDEO_DURATION_SECONDS=8
DEFAULT_VIDEO_ASPECT_RATIO=9:16
DEFAULT_VIDEO_RESOLUTION=1080x1920
MAX_BATCH_SIZE=50
MAX_CONCURRENT_JOBS_PER_TENANT=5

# --------------------------
# Observability
# --------------------------
LOG_LEVEL=info
# Options: debug, info, warning, error
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# --------------------------
# Feature Flags
# --------------------------
FEATURE_BATCH_MODE=false
FEATURE_PREMIUM_ROUTE=false
FEATURE_AUDIO_GENERATION=false
FEATURE_VIRTUAL_TRYON=true
FEATURE_ANALYTICS_DASHBOARD=false

# --------------------------
# Admin
# --------------------------
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_SECRET=change-me-admin-secret

# --------------------------
# CORS
# --------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
