# douyin-fashion-ai Demo — Environment Config
# Copy to .env and edit as needed
# All inference is MOCKED by default — no API keys required for the demo

APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=demo-secret-key-change-in-production
APP_BASE_URL=http://localhost:8000

# Set to 'real' to enable actual API calls (requires API keys below)
INFERENCE_MODE=mock

# Kling (primary video model)
KLING_API_KEY=
KLING_API_BASE_URL=https://api.klingai.com/v1
KLING_DEFAULT_MODEL=kling-v3

# Veo (premium route)
VEO_API_KEY=
VEO_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
VEO_DEFAULT_MODEL=veo-3.1

# Fallback / economy route
FALLBACK_PROVIDER_API_KEY=
FALLBACK_PROVIDER_BASE_URL=

# Default generation settings
DEFAULT_VIDEO_DURATION_SECONDS=8
DEFAULT_VIDEO_ASPECT_RATIO=9:16
DEFAULT_VIDEO_RESOLUTION=1080x1920

# Prompt enhancement
PROMPT_ENHANCEMENT_ENABLED=true
PROMPT_LANGUAGE_DEFAULT=zh-CN

# Logging
LOG_LEVEL=info

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
